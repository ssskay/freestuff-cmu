---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import ScenarioIcon from '../../components/ScenarioIcon.astro';
import { loadResources } from '../../lib/catalog';
import { SITE, SCENARIOS } from '../../site.config';

// Resolve the catalog (Supabase with static JSON fallback), id = stable slug.
const resources = await loadResources();

// Resources curated for this scenario (membership defined in site.config).
const scenarioResources = resources.filter(SCENARIOS['adventure'].match);
---

<BaseLayout title={`Adventure Resources | ${SITE.name}`}>
  <div class="scenario-page">
    <div class="scenario-hero">
      <div class="scenario-icon-large"><ScenarioIcon slug="adventure" size={48} /></div>
      <h1 class="scenario-title">New to Pittsburgh?</h1>
      <p class="scenario-description">
        Whether you're new to Pittsburgh, planning a weekend out, or just want to explore — your free transit pass gets you anywhere in the city, and the Arts Pass gets you into eight museums for free. No car, no cover charges, no membership required.
      </p>
    </div>

    <div class="scenario-content">
      <div class="scenario-section">
        <h2 class="section-title">What you'll find here</h2>
        <ul class="benefit-list">
          <li><strong>Free Pittsburgh Transit (PRT)</strong> — Unlimited bus, light-rail, and incline rides through the Ready2Ride app. Get anywhere in the city for free.</li>
          <li><strong>CMU Arts Pass</strong> — Free admission to eight Pittsburgh venues, including all four Carnegie Museums, Phipps Conservatory, and the National Aviary.</li>
          <li><strong>Intramural Sports</strong> — Year-round recreational leagues and tournaments across all skill levels. Register a team or join as a free agent online.</li>
          <li><strong>NightSafe Transit</strong> — Free late-night shuttle to Oakland, Shadyside, and Squirrel Hill, 6:30 p.m.–4:15 a.m. Get home safe at no cost.</li>
          <li><strong>Miller ICA</strong> — Free admission to CMU's contemporary art gallery, right in the Purnell Center.</li>
        </ul>
      </div>

      <div class="resources-section">
        <h2 class="section-title">Your resources ({scenarioResources.length})</h2>
        <div class="resource-grid">
          {scenarioResources.map((resource) => (
            <div class="resource-item">
              <ResourceCard resource={resource} />
            </div>
          ))}
        </div>
      </div>

      <div class="cta-section">
        <p class="cta-text">Need something else?</p>
        <a href="/" class="cta-button">Browse all {resources.length} resources</a>
        <a href="/scenarios" class="cta-link-secondary">See other scenarios →</a>
      </div>
    </div>
  </div>

  <style>
    .scenario-page {
      max-width: 90rem;
      margin: 0 auto;
      padding: var(--space-2xl) var(--space-lg);
    }

    .scenario-hero {
      max-width: var(--measure);
      margin: 0 auto var(--space-3xl);
      text-align: center;
    }

    .scenario-icon-large {
      font-size: var(--text-6xl);
      line-height: 1;
      margin-bottom: var(--space-md);
    }

    .scenario-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-4xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
    }

    .scenario-description {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      margin: 0;
    }

    .scenario-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-3xl);
    }

    .scenario-section {
      max-width: var(--measure);
      margin: 0 auto;
    }

    .section-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-2xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
    }

    .benefit-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .benefit-list li {
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      padding-left: var(--space-lg);
      position: relative;
    }

    .benefit-list li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: var(--color-accent);
      font-weight: 600;
    }

    .resources-section {
      width: 100%;
    }

    .resource-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .cta-section {
      max-width: var(--measure);
      margin: 0 auto;
      text-align: center;
      padding: var(--space-2xl) 0;
      border-top: var(--rule-thin) solid var(--color-border);
    }

    .cta-text {
      margin: 0 0 var(--space-md) 0;
      font-size: var(--text-lg);
      color: var(--color-ink-muted);
    }

    .cta-button {
      display: inline-block;
      padding: var(--space-sm) var(--space-lg);
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--color-paper);
      background: var(--color-accent);
      border: none;
      border-radius: var(--radius-sm);
      text-decoration: none;
      cursor: pointer;
      transition: background var(--dur-fast) var(--ease-out);
    }

    .cta-button:hover {
      background: var(--color-accent-hover);
    }

    .cta-link-secondary {
      display: block;
      margin-top: var(--space-sm);
      font-size: var(--text-base);
      font-weight: 500;
      color: var(--color-accent);
      text-decoration: none;
      transition: color var(--dur-fast) var(--ease-out);
    }

    .cta-link-secondary:hover {
      color: var(--color-accent-hover);
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .scenario-page {
        padding: var(--space-xl) var(--space-md);
      }

      .scenario-title {
        font-size: var(--text-3xl);
      }

      .scenario-description {
        font-size: var(--text-base);
      }

      .section-title {
        font-size: var(--text-xl);
      }

      .resource-grid {
        grid-template-columns: 1fr;
        gap: var(--space-md);
      }
    }
  </style>


  <script>
    import { initResourceInteractions } from '../../lib/resource-interactions';

    // Upvote + report behavior (shared across all pages).
    initResourceInteractions();
  </script>
</BaseLayout>
